{
  "compilerOptions": {
    "target": "es2015",
    "types": ["node"],
    "skipLibCheck": true,
    "lib": [
      "esnext.asynciterable",
      "dom",
      "es6",
      "dom.iterable",
      "scripthost",
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "graphql-middleware": ["./node_modules/graphql-middleware/dist/index.d.ts"]
    }
  },
  "include": [
    "src/*"
  ]
}
